include "meta.mal"

let stack_used: s64
let params_stack_used: s64
let sorted_var_indices: &s64

proc get_type_size(index: s64) -> s64
  let kind = type_kinds[index]

  if kind == 0 as s8
    retval 0
  elif kind == 1 as s8
    retval 8
  elif kind == 2 as s8
    retval 1
  elif kind == 3 as s8
    retval 2
  elif kind == 4 as s8
    retval 4
  elif kind == 5 as s8
    retval 8
  end

  retval 0
end

proc var_collides_at_reg_index(vbegin: s64, vend: s64, index: s64, max_vars: s64) -> s8
  let i = 0

  while i < max_vars
    let temp_vbegin = var_begins[sorted_var_indices[i]]
    let temp_vend = var_ends[sorted_var_indices[i]]
    let temp_vindex = var_indices[sorted_var_indices[i]]

    if (temp_vindex == index) &
       (((temp_vbegin >= vbegin) & (temp_vbegin < vend)) |
        ((temp_vend > vbegin) & (temp_vend <= vend)) |
        ((temp_vbegin <= vbegin) & (temp_vend >= vend)))
      retval 1 as s8
    end

    i = i + 1
  end

  retval 0 as s8
end

proc var_get_no_collision_reg_index(vbegin: s64, vend: s64, max_vars: s64) -> s64
  let REGS_COUNT = 5

  let i = 0

  while i < REGS_COUNT
    let collides = var_collides_at_reg_index(vbegin, vend, i, max_vars)

    if collides == 0 as s8
      retval i
    end

    i = i + 1
  end

  retval -1
end

proc alloc_regs_for_proc(index: s64)
  sorted_var_indices = malloc(vars_len * sizeof s64) as &s64

  let params_len = ir_proc_params_lens[index]

  let i = 0

  while i < vars_len
    sorted_var_indices[i] = i

    i = i + 1
  end

  i = params_len

  while i + 1 < vars_len
    let j = 0

    while j + i + 1 < vars_len
      let a = var_uses[sorted_var_indices[j]]
      let b = var_uses[sorted_var_indices[j + 1]]

      if a < b
        let temp = sorted_var_indices[j]
        sorted_var_indices[j] = sorted_var_indices[j + 1]
        sorted_var_indices[j + 1] = temp
      end

      j = j + 1
    end

    i = i + 1
  end

  stack_used = 0
  params_stack_used = 16

  i = 0

  while i < params_len
    var_indices[i] = -1
    var_offsets[i] = params_stack_used
    params_stack_used = params_stack_used + get_type_size(var_types[i])

    i = i + 1
  end

  i = params_len

  while i < vars_len
    let vbegin = var_begins[sorted_var_indices[i]]
    let vend = var_ends[sorted_var_indices[i]]

    let reg_index = var_get_no_collision_reg_index(vbegin, vend, i)

    if (reg_index == -1) | var_is_ref_targets[sorted_var_indices[i]]
      stack_used = stack_used + get_type_size(var_types[sorted_var_indices[i]])
      var_indices[sorted_var_indices[i]] = -1
      var_offsets[sorted_var_indices[i]] = 0 - stack_used
    else
      var_indices[sorted_var_indices[i]] = reg_index
    end

    i = i + 1
  end

  free(sorted_var_indices as &s8)
end
