whitespace=( |\t|\r)*
newline=\n
comment=#

proc=proc
end=end
let=let
ret=ret
retval=retval
extern=extern
as=as
if=if
elif=elif
else=else
while=while
include=include

assign==
oparen=\(
cparen=\)
str="|'
colon=:
amp=&
arrow=\->
comma=,
plus=\+
minus=\-
star=\*
slash=/
perc=%
cassign=:=
eq===
ne=!=
ls=<
le=<=
gt=>
ge=>=

int=\-?0-9+
ident=(_|a-z|A-Z)(_|a-z|A-Z|0-9)*
