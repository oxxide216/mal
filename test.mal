proc main() -> s32
  one()
  str = "Hello, World!\n"
  result = args(2, 2)
  print_14_bytes(str)
  retval result
end

proc one() -> s32
  retval 1
end

proc var() -> s32
  c = 1
  a = 2
  b = a
  d = c
  retval b
end

proc args(a: s32, b: s32) -> s32
  retval a
end

proc print_14_bytes(bytes: &u8)
  "mov rdx,14"
  "mov rsi,rdi"
  "mov rdi,1"
  "mov rax,1"
  "syscall"
end
