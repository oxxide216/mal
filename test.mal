proc main() -> s32
  str0 = "Hello, World!\n"
  str1 = "Foo, Bar!\n"
  str2 = "Bazz!\n"
  if 0
    print(str0, 14)
  elif 1
    print(str2, 6)
  else
    print(str1, 10)
  end
  retval 0
end

proc var() -> s32
  c = 1
  a = 2
  b = a
  d = c
  retval b
end

proc print(bytes: &u8, size: s32)
  "mov rdx,rsi"
  "mov rsi,rdi"
  "mov rdi,1"
  "mov rax,1"
  "syscall"
end
