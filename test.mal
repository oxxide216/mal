proc main() -> s32
  str0 = "Hello, World!\n"
  str1 = "Foooo, Baaar!\n"
  if 1
    print_14_bytes(str0)
  end
  retval 0
end

proc var() -> s32
  c = 1
  a = 2
  b = a
  d = c
  retval b
end

proc print_14_bytes(bytes: &u8)
  "mov rdx,14"
  "mov rsi,rdi"
  "mov rdi,1"
  "mov rax,1"
  "syscall"
end
