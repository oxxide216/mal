proc main() -> u8
  str0 = "Hello, World!\n"
  str1 = "Foo, Bar!\n"
  str2 = "Bazz!\n"
  if 0 != 0
    print(str0, 14)
  elif 1 == 1
    print(str2, 6)
  else
    print(str1, 10)
  end
  i = 0
  while i < 10
    print("In a loop!\n", 11)
    i = i + 1
  end
  a = 5
  r = &a
  *r = 2
  b = *r
  c = a + b
  d = c as u8
  retval d
end

proc var() -> s32
  c = 1
  a = 2
  b = a
  d = c
  retval b
end

proc print(bytes: &u8, size: s32)
  "mov rdx,rsi"
  "mov rsi,rdi"
  "mov rdi,1"
  "mov rax,1"
  "syscall"
end
