(macro count \->
  (let prev counter)
  (set counter (+ counter 1))
  prev)

(macro count \init ->
  (set counter (+ init 1))
  init)

(macro ! \expr ->
  (let value expr)
  (if (unit? value)
    (ret value))
  value)

(macro ? \expr ->
  (let value expr)
  (if (unit? value)
    (ret unit))
  value)

(let counter 0)

(let TT-WHITESPACE (count 0))
(let TT-COMMENT    (count))
(let TT-INT        (count))
(let TT-RETVAL     (count))
(let TT-PROC       (count))
