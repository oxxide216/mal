(let TT-AS         (count))
(let TT-STRUCT     (count))
(let TT-LET        (count))
(let TT-IDENT      (count))
(let TT-OPAREN     (count))
(let TT-CPAREN     (count))
(let TT-ASSIGN     (count))
(let TT-COMMA      (count))
